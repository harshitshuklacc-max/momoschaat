generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  CUSTOMER
}

enum ProductStatus {
  ACTIVE
  DISABLED
  DRAFT
}

enum Gender {
  MEN
  WOMEN
  UNISEX
  KIDS
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
  REFUNDED
}

enum OrderType {
  ONLINE
  OFFLINE
}

enum PaymentMethod {
  COD
  UPI
  CASH
  CARD
}

enum PaymentStatus {
  PENDING
  PENDING_VERIFICATION
  VERIFIED
  REJECTED
  COMPLETED
  FAILED
  REFUNDED
}

enum InventoryAction {
  SALE
  RETURN
  CANCELLATION
  ADJUSTMENT
  BUSY_IMPORT
  RESTOCK
  POS_SALE
  ONLINE_ORDER
}

enum BarcodeType {
  CODE128
  EAN13
  QR
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  ORDER
  PAYMENT
  INVENTORY
  SYSTEM
  PROMOTION
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
  FACTORY_RESET
  VERIFY_PAYMENT
  BULK_UPDATE
  BULK_DELETE
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
}

enum RefundStatus {
  PENDING
  PROCESSED
  REJECTED
}

model Admin {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  email        String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sessions   Session[]
  auditLogs  AuditLog[]
  imports    BusyImportLog[]

  @@map("admins")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(CUSTOMER)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  customer Customer?
  sessions Session[]

  @@index([email])
  @@map("users")
}

model Customer {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  phone     String?
  avatar    String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders        Order[]
  reviews       Review[]
  wishlists     Wishlist[]
  addresses     Address[]
  notifications Notification[]

  @@index([phone])
  @@map("customers")
}

model Brand {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  logo        String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  products Product[]

  @@map("brands")
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  image       String?
  parentId    String?  @map("parent_id")
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  products Product[]

  @@index([slug])
  @@map("categories")
}

model Product {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  description   String?
  brandId       String        @map("brand_id")
  categoryId    String        @map("category_id")
  mrp           Decimal       @db.Decimal(12, 2)
  sellingPrice  Decimal       @map("selling_price") @db.Decimal(12, 2)
  discount      Decimal       @default(0) @db.Decimal(5, 2)
  sku           String        @unique
  color         String?
  size          String?
  gender        Gender        @default(UNISEX)
  status        ProductStatus @default(ACTIVE)
  isFeatured    Boolean       @default(false) @map("is_featured")
  isTrending    Boolean       @default(false) @map("is_trending")
  isNewArrival  Boolean       @default(false) @map("is_new_arrival")
  isBestSeller  Boolean       @default(false) @map("is_best_seller")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  brand        Brand          @relation(fields: [brandId], references: [id])
  category     Category       @relation(fields: [categoryId], references: [id])
  images       ProductImage[]
  inventory    Inventory?
  barcode      Barcode?
  orderItems   OrderItem[]
  invoiceItems InvoiceItem[]
  reviews      Review[]
  wishlists    Wishlist[]

  @@index([brandId])
  @@index([categoryId])
  @@index([status])
  @@index([sku])
  @@index([isFeatured])
  @@index([isTrending])
  @@index([isNewArrival])
  @@index([isBestSeller])
  @@map("products")
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  url       String
  alt       String?
  sortOrder Int      @default(0) @map("sort_order")
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model Inventory {
  id        String   @id @default(cuid())
  productId String   @unique @map("product_id")
  quantity  Int      @default(0)
  reserved  Int      @default(0)
  minStock  Int      @default(5) @map("min_stock")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  logs    InventoryLog[]

  @@index([quantity])
  @@map("inventory")
}

model InventoryLog {
  id          String          @id @default(cuid())
  inventoryId String          @map("inventory_id")
  action      InventoryAction
  quantity    Int
  previousQty Int             @map("previous_qty")
  newQty      Int             @map("new_qty")
  reference   String?
  notes       String?
  createdAt   DateTime        @default(now()) @map("created_at")

  inventory Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@index([inventoryId])
  @@index([action])
  @@index([createdAt])
  @@map("inventory_logs")
}

model Barcode {
  id        String      @id @default(cuid())
  productId String      @unique @map("product_id")
  value     String      @unique
  type      BarcodeType @default(CODE128)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([value])
  @@map("barcodes")
}

model BusyImportLog {
  id           String   @id @default(cuid())
  adminId      String?  @map("admin_id")
  fileName     String   @map("file_name")
  totalRows    Int      @default(0) @map("total_rows")
  addedCount   Int      @default(0) @map("added_count")
  updatedCount Int      @default(0) @map("updated_count")
  skippedCount Int      @default(0) @map("skipped_count")
  failedCount  Int      @default(0) @map("failed_count")
  details      Json?
  status       String   @default("completed")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  admin Admin? @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@map("busy_import_logs")
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique @map("order_number")
  customerId      String?       @map("customer_id")
  customerName    String?       @map("customer_name")
  customerPhone   String?       @map("customer_phone")
  customerEmail   String?       @map("customer_email")
  type            OrderType     @default(ONLINE)
  status          OrderStatus   @default(PENDING)
  subtotal        Decimal       @db.Decimal(12, 2)
  discount        Decimal       @default(0) @db.Decimal(12, 2)
  tax             Decimal       @default(0) @db.Decimal(12, 2)
  shipping        Decimal       @default(0) @db.Decimal(12, 2)
  grandTotal      Decimal       @map("grand_total") @db.Decimal(12, 2)
  paymentMethod   PaymentMethod @map("payment_method")
  shippingAddress Json?         @map("shipping_address")
  notes           String?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  customer Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items    OrderItem[]
  payments Payment[]
  invoice  Invoice?
  returns  Return[]

  @@index([customerId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([orderNumber])
  @@map("orders")
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String   @map("order_id")
  productId String   @map("product_id")
  name      String
  sku       String
  barcode   String?
  quantity  Int
  price     Decimal  @db.Decimal(12, 2)
  discount  Decimal  @default(0) @db.Decimal(12, 2)
  total     Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Payment {
  id            String        @id @default(cuid())
  orderId       String        @map("order_id")
  method        PaymentMethod
  amount        Decimal       @db.Decimal(12, 2)
  status        PaymentStatus @default(PENDING)
  transactionId String?       @map("transaction_id")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  order        Order                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
  verification PaymentVerification?

  @@index([orderId])
  @@index([status])
  @@map("payments")
}

model PaymentVerification {
  id              String        @id @default(cuid())
  paymentId       String        @unique @map("payment_id")
  upiReference    String?       @map("upi_reference")
  screenshotUrl   String?       @map("screenshot_url")
  status          PaymentStatus @default(PENDING_VERIFICATION)
  verifiedBy      String?       @map("verified_by")
  verifiedAt      DateTime?     @map("verified_at")
  rejectionReason String?       @map("rejection_reason")
  notes           String?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("payment_verifications")
}

model Invoice {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique @map("invoice_number")
  orderId       String?  @unique @map("order_id")
  customerName  String   @map("customer_name")
  customerPhone String?  @map("customer_phone")
  subtotal      Decimal  @db.Decimal(12, 2)
  discount      Decimal  @default(0) @db.Decimal(12, 2)
  tax           Decimal  @default(0) @db.Decimal(12, 2)
  grandTotal    Decimal  @map("grand_total") @db.Decimal(12, 2)
  paymentMethod String   @map("payment_method")
  storeName     String   @map("store_name")
  storeAddress  String   @map("store_address")
  storePhone    String   @map("store_phone")
  isArchived    Boolean  @default(false) @map("is_archived")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  order Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  items InvoiceItem[]

  @@index([invoiceNumber])
  @@index([createdAt])
  @@index([isArchived])
  @@map("invoices")
}

model InvoiceItem {
  id        String   @id @default(cuid())
  invoiceId String   @map("invoice_id")
  productId String?  @map("product_id")
  name      String
  sku       String
  barcode   String?
  quantity  Int
  price     Decimal  @db.Decimal(12, 2)
  discount  Decimal  @default(0) @db.Decimal(12, 2)
  total     Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at")

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@map("invoice_items")
}

model Review {
  id         String       @id @default(cuid())
  productId  String       @map("product_id")
  customerId String       @map("customer_id")
  orderId    String?      @map("order_id")
  rating     Int
  title      String?
  comment    String?
  images     Json?
  status     ReviewStatus @default(PENDING)
  isVerified Boolean      @default(false) @map("is_verified")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([customerId])
  @@index([status])
  @@map("reviews")
}

model Wishlist {
  id         String   @id @default(cuid())
  customerId String   @map("customer_id")
  productId  String   @map("product_id")
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
  @@index([customerId])
  @@map("wishlists")
}

model Address {
  id         String   @id @default(cuid())
  customerId String   @map("customer_id")
  label      String   @default("Home")
  fullName   String   @map("full_name")
  phone      String
  line1      String
  line2      String?
  city       String
  state      String
  pincode    String
  country    String   @default("India")
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("addresses")
}

model Notification {
  id         String           @id @default(cuid())
  customerId String?          @map("customer_id")
  title      String
  message    String
  type       NotificationType @default(SYSTEM)
  isRead     Boolean          @default(false) @map("is_read")
  data       Json?
  createdAt  DateTime         @default(now()) @map("created_at")

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([isRead])
  @@map("notifications")
}

model AuditLog {
  id         String      @id @default(cuid())
  adminId    String?     @map("admin_id")
  action     AuditAction
  entity     String
  entityId   String?     @map("entity_id")
  details    Json?
  ipAddress  String?     @map("ip_address")
  userAgent  String?     @map("user_agent")
  createdAt  DateTime    @default(now()) @map("created_at")

  admin Admin? @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([adminId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  group     String   @default("general")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([group])
  @@map("settings")
}

model HomepageSetting {
  id        String   @id @default(cuid())
  section   String   @unique
  title     String?
  subtitle  String?
  content   Json?
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("homepage_settings")
}

model HeroBanner {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  image     String
  link      String?
  buttonText String? @map("button_text")
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isActive])
  @@map("hero_banners")
}

model Return {
  id        String       @id @default(cuid())
  orderId   String       @map("order_id")
  reason    String
  status    ReturnStatus @default(REQUESTED)
  notes     String?
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  order  Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  refund Refund?

  @@index([orderId])
  @@index([status])
  @@map("returns")
}

model Refund {
  id        String       @id @default(cuid())
  returnId  String       @unique @map("return_id")
  amount    Decimal      @db.Decimal(12, 2)
  status    RefundStatus @default(PENDING)
  method    String?
  reference String?
  notes     String?
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  return Return @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("refunds")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String?  @map("user_id")
  adminId   String?  @map("admin_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user  User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  admin Admin? @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([expiresAt])
  @@map("sessions")
}

model Coupon {
  id            String   @id @default(cuid())
  code          String   @unique
  description   String?
  discountType  String   @map("discount_type")
  discountValue Decimal  @map("discount_value") @db.Decimal(12, 2)
  minOrderValue Decimal? @map("min_order_value") @db.Decimal(12, 2)
  maxDiscount   Decimal? @map("max_discount") @db.Decimal(12, 2)
  usageLimit    Int?     @map("usage_limit")
  usedCount     Int      @default(0) @map("used_count")
  isActive      Boolean  @default(true) @map("is_active")
  startsAt      DateTime? @map("starts_at")
  expiresAt     DateTime? @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([code])
  @@index([isActive])
  @@map("coupons")
}
